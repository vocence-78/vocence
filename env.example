# =============================================================================
# MINER
# =============================================================================


WALLET_NAME=
HOTKEY_NAME=
CHUTES_API_KEY=

# Optional: for HuggingFace models
# HF_AUTH_TOKEN=









# =============================================================================
# VALIDATOR
# =============================================================================

WALLET_NAME=
HOTKEY_NAME=
CHUTES_API_KEY=
OPENAI_AUTH_KEY=
VALIDATOR_NAME= #your validator name
VALIDATOR_ID= #your validator number given by subnet owner
API_URL= #subnet API url.
HIPPIUS_VALIDATOR_ACCESS_KEY= #validator's own hippius bucket access keys
HIPPIUS_VALIDATOR_SECRET_KEY=

# Local audio corpus (per-validator; English LibriVox clips downloaded to disk).
# No corpus bucket / owner credentials are needed — each validator builds its own.
CORPUS_LOCAL_DIR=./data/corpus
AUDIO_CORPUS_MAX_ENTRIES=10000
# Cadence (defaults shown). Fast while filling, slow once full, backoff on 429:
# SOURCE_AUDIO_DOWNLOAD_INTERVAL=60      # seconds between pulls while below cap (filling)
# CORPUS_REFRESH_INTERVAL_SEC=3600       # seconds between pulls once at cap (freshness rotation)
# CORPUS_RATE_LIMIT_BACKOFF_SEC=900      # max backoff when LibriVox returns HTTP 429
VALIDATOR_BUCKETS_JSON='[{"hotkey":"5F...","bucket_name":"vocence-samples-rt21","access_key":"readonly-access-key","secret_key":"readonly-secret-key"},{"hotkey":"5G...","bucket_name":"vocence-samples-rizzo","access_key":"readonly-access-key","secret_key":"readonly-secret-key"},{"hotkey":"5H...","bucket_name":"vocence-samples-kraken","access_key":"readonly-access-key","secret_key":"readonly-secret-key"}]'

NETWORK=finney
NETUID=78
CYCLE_LENGTH=150
MIN_EVALS_TO_COMPETE=40
ACTIVE_VALIDATOR_WINDOW_HOURS=24
MIN_ACTIVE_VALIDATORS_FOR_GLOBAL_SCORING=3
MIN_VALIDATOR_APPEARANCES_FOR_ELIGIBILITY=3
MIN_EVALS_PER_VALIDATOR_FOR_GLOBAL_SCORE=1
VALIDATOR_LOCAL_SAMPLES_DIR=./samples
LOG_LEVEL=INFO









# =============================================================================
# OWNER (dashboard API service only — `vocence api`)
# =============================================================================

# Optional: override DB (defaults: localhost:5432, user vocence, db vocence)
# DB_CONNECTION_STRING=postgresql://user:pass@host:5432/vocence
